# IDS Institucional - variables sensibles
# Copiar este archivo como .env y completar valores reales.
# No subir .env a repositorios ni compartir contrasenas o API Keys.

SMTP_ENABLED=false
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_STARTTLS=true
SMTP_USER=correo_admin@example.com
SMTP_PASSWORD=app_password_aqui
SMTP_FROM=ids@example.com
ADMIN_EMAIL=admin@example.com
ALERT_COOLDOWN_SECONDS=300

THREAT_INTEL_API_KEY=colocar_api_key_aqui
